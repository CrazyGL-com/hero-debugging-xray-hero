      "import": "./dist/index.js"
    },
    "./metadata.json": "./metadata.json",
    "./style.css": "./style.css"
  },
  "files": [
    "dist",
    "metadata.json",
    "style.css",
    "LICENSE"
  ],
  "dependencies": {
    "@crazygl/core": "^0.1.0",
    "three": ">=0.160"
  },
